rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requesting user an admin?
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── userInvites ──────────────────────────────────────────────────────────────
    // Any authenticated user can read (needed for the client-side allowlist check).
    // Only admins can write — invites are managed via the admin panel.
    match /userInvites/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // ── users ────────────────────────────────────────────────────────────────────
    // Authenticated users can read any user doc (needed for admin panel lookups,
    // and for ensureUserDocument to check for pre-created email-keyed docs).
    // Users can write their own UID-keyed doc (ensureUserDocument on first login).
    // Admins can write any doc (updateUserRole, createUser).
    match /users/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.uid == docId || isAdmin());
    }

    // ── mas ──────────────────────────────────────────────────────────────────────
    // Any authenticated user can read MA profiles.
    // Admins can do anything (create, update, delete).
    // MAs can update their own profile doc (bio edits, memo upload).
    match /mas/{maId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (request.auth != null
            && exists(/databases/$(database)/documents/users/$(request.auth.uid))
            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.maId == maId);
    }

    // ── comments ─────────────────────────────────────────────────────────────────
    // Any authenticated user can read and create.
    // Authors can edit/delete their own; admins can delete any.
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && resource.data.authorUid == request.auth.uid;
      allow delete: if request.auth != null
        && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // ── reactions ────────────────────────────────────────────────────────────────
    // Any authenticated user can read and write reactions.
    match /reactions/{reactionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
